{
  auto_https off
}

:80 {
  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "no-referrer"
  }

  handle_path /api/* {
    reverse_proxy api:8000
  }

  handle /health {
    reverse_proxy api:8000
  }
  handle /metrics {
    reverse_proxy api:8000
  }

  handle {
    respond "Acquisition Engine (public) is running.
- Public API: /api/
" 200
  }
}
